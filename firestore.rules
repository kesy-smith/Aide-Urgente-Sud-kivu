rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- 3. Primitives & Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isVerified() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- 2. Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'role', 'createdAt'])
        && data.uid is string && data.uid.size() <= 128
        && data.displayName is string && data.displayName.size() <= 100
        && data.role in ['user', 'volunteer', 'ngo']
        && (!data.keys().contains('phoneNumber') || (data.phoneNumber is string && data.phoneNumber.size() <= 20))
        && (!data.keys().contains('email') || (data.email is string && data.email.size() <= 100))
        && (!data.keys().contains('rating') || (data.rating is number))
        && (!data.keys().contains('totalHelped') || (data.totalHelped is number))
        && data.createdAt is timestamp
        && (!data.keys().contains('updatedAt') || data.updatedAt is timestamp);
    }

    function isValidRequest(data) {
      return data.keys().hasAll(['title', 'category', 'location', 'contact', 'status', 'userId', 'createdAt', 'userName'])
        && data.title is string && data.title.size() <= 150
        && data.category in ['medical', 'food', 'financial', 'emergency']
        && data.location is map
        && data.location.area is string && data.location.area.size() <= 100
        && data.contact is string && data.contact.size() <= 50
        && data.status in ['open', 'in_progress', 'resolved']
        && data.userId is string && data.userId.size() <= 128
        && data.userName is string && data.userName.size() <= 100
        && data.createdAt is timestamp
        && (!data.keys().contains('updatedAt') || data.updatedAt is timestamp);
    }

    // --- 4. Middlewares & Master Gates ---

    match /test/connection {
      allow get: if true;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      // DEBUG: Simplified create and update to isolate permission failure
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      
      // Restored but commented out for reference during debug
      /*
      allow update: if isVerified() && isOwner(userId) && isValidId(userId)
        && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'phoneNumber', 'role', 'rating', 'totalHelped', 'email', 'updatedAt']);
      */
    }

    match /requests/{requestId} {
      // Secure List Query: Enforce relational or status-based check on each document
      // Client query MUST include: where('status', 'in', ['open', 'in_progress', 'resolved'])
      allow list: if isSignedIn() && resource.data.status in ['open', 'in_progress', 'resolved'];
      allow get: if isSignedIn() && isValidId(requestId);
      
      allow create: if isSignedIn() && isValidId(requestId)
        // DEBUG: Step 1 - check if basic identity and ID validity pass
        && incoming().userId == request.auth.uid;

      allow update: if isVerified() && isValidId(requestId)
        && (
          // Action: Owner Update
          (isOwner(existing().userId) && isValidRequest(incoming()) 
            && incoming().createdAt == existing().createdAt
            && (!incoming().keys().contains('updatedAt') || incoming().updatedAt == request.time))
          ||
          // Action: Volunteer Response
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'volunteerId', 'updatedAt']) 
            && incoming().status in ['in_progress', 'resolved']
            && incoming().updatedAt == request.time
            && (existing().status == 'open' || (existing().status == 'in_progress' && incoming().status == 'resolved')))
        );

      allow delete: if isVerified() && isOwner(resource.data.userId) && isValidId(requestId);
    }
  }
}
